        [ dash:editor dash:AutoCompleteEditor ;
            dash:viewer dash:LabelViewer ;
            sh:class :Origin_Role_Player ;
            sh:group :RolesPropertyGroup ;
            sh:name "origin"@en ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path :origin ],
        [ dash:editor dash:AutoCompleteEditor ;
            dash:viewer dash:LabelViewer ;
            sh:class :Trajectory_Role_Player ;
            sh:group :RolesPropertyGroup ;
            sh:name "trajectory"@en ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path :trajectory ],
        [ dash:editor dash:AutoCompleteEditor ;
            dash:viewer dash:LabelViewer ;
            sh:class :Result_Role_Player ;
            sh:group :RolesPropertyGroup ;
            sh:name "result"@en ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path :result ],
        [ dash:editor dash:AutoCompleteEditor ;
            dash:viewer dash:LabelViewer ;
            sh:class :Destination_Role_Player ;
            sh:group :RolesPropertyGroup ;
            sh:name "destination"@en ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path :destination ],
        [ dash:editor dash:AutoCompleteEditor ;
            dash:viewer dash:LabelViewer ;
            sh:class :Position_Role_Player ;
            sh:group :RolesPropertyGroup ;
            sh:name "position"@en ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path :position ] ;
    sh:rule [ a sh:SPARQLRule ;
            sh:construct """
        PREFIX : <https://falcontologist.github.io/shacl-demo/ontology/>
        
        CONSTRUCT {
            ?mover ?opaqueProperty ?theme .
        }
        WHERE {
            ?this a :Motion ;
                  :lemma ?lemma ;
