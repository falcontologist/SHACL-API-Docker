    sh:rule [ a sh:SPARQLRule ;
            sh:construct """
        PREFIX : <https://falcontologist.github.io/shacl-demo/ontology/>
        
        CONSTRUCT {
            ?mover ?opaqueProperty ?affectee .
        }
        WHERE {
            ?this a :Basic_Incremental ;
                  :lemma ?lemma ;
