:Measurement_shape a sh:NodeShape,
        :Situation_shape ;
    rdfs:label "Measurement (shape)"@en ;
    dash:defaultViewForRole dash:all ;
    sh:property [ dash:editor dash:AutoCompleteEditor ;
            dash:viewer dash:LabelViewer ;
            sh:class :Unit_Role_Player ;
            sh:group :RolesPropertyGroup ;
            sh:name "unit"@en ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path :unit ],
        [ dash:editor dash:AutoCompleteEditor ;
            dash:viewer dash:LabelViewer ;
            sh:class :Item_Role_Player ;
            sh:group :RolesPropertyGroup ;
            sh:name "item"@en ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path :item ],
        [ dash:editor dash:AutoCompleteEditor ;
            dash:nillable true ;
            dash:viewer dash:LabelViewer ;
            sh:class :Value_Role_Player ;
            sh:group :RolesPropertyGroup ;
            sh:name "value"@en ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path :value ],
        [ dash:editor dash:AutoCompleteEditor ;
            dash:viewer dash:LabelViewer ;
            sh:class :Multiplier_Role_Player ;
            sh:group :RolesPropertyGroup ;
            sh:name "multiplier"@en ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path :multiplier ] ;
    sh:rule [ a sh:SPARQLRule ;
            sh:construct """
            PREFIX : <https://falcontologist.github.io/shacl-demo/ontology/>
            PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
            CONSTRUCT {
                ?item :costs ?quantity .
            }
            WHERE {
                ?this :item ?item .
                ?this :value ?val .
                ?this :unit ?uNode .
                ?uNode rdfs:label ?uLabel .
                
                # Optional multiplier handling
                OPTIONAL { 
                    ?this :multiplier ?mNode .
                    ?mNode rdfs:label ?mLabel .
                }
                
                # Concatenate the literal: e.g., "32" + " Billion" + " USD"
                BIND(IF(BOUND(?mLabel), CONCAT(STR(?val), " ", STR(?mLabel), " ", STR(?uLabel)), CONCAT(STR(?val), " ", STR(?uLabel))) AS ?quantity)
            }
        """ ;
            sh:order 7 ;
            sh:prefixes :Ontology_Prefixes ] ;
    sh:targetClass :Measurement .

