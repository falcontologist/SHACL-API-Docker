            sh:class :Attribute_Role_Player ;
            sh:group :RolesPropertyGroup ;
            sh:name "attribute"@en ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path :attribute ],
        [ dash:editor dash:AutoCompleteEditor ;
            dash:viewer dash:LabelViewer ;
            sh:class :Manner_Role_Player ;
            sh:group :RolesPropertyGroup ;
            sh:name "manner"@en ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path :manner ],
        [ dash:editor dash:AutoCompleteEditor ;
            dash:viewer dash:LabelViewer ;
            sh:class :Material_Role_Player ;
            sh:group :RolesPropertyGroup ;
            sh:name "material"@en ;
            sh:nodeKind sh:BlankNodeOrIRI ;
