@prefix : <https://falcontologist.github.io/shacl-demo/ontology/> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:Information_Entity a rdfs:Class,
        sh:NodeShape ;
    rdfs:label "Information Entity"@en .

:Manner_Entity a rdfs:Class,
        sh:NodeShape ;
    rdfs:label "Manner Entity"@en .

:Numerical_Multiplier_Entity a rdfs:Class,
        sh:NodeShape ;
    rdfs:label "Numerical Multiplier Entity"@en .

:Substance_Entity a rdfs:Class,
        sh:NodeShape ;
    rdfs:label "Substance Entity"@en .

:Unit_Entity a rdfs:Class,
        sh:NodeShape ;
    rdfs:label "Unit Entity"@en .

:Unknown_Entity a rdfs:Class,
        sh:NodeShape ;
    rdfs:label "Unknown Entity"@en ;
    sh:description "An existential placeholder for a required role where the specific entity or value is unknown or undisclosed."@en .

:Absorb_shape a sh:NodeShape,
        :Situation_shape ;
    rdfs:label "Absorb (shape)"@en ;
    dash:defaultViewForRole dash:all ;
    skos:example "More than 7.4 million people with diabetes take insulin every year."@en ;
    sh:description "A situation where an entity takes in, incorporates, or assimilates another entity or substance."@en ;
    sh:property [ dash:editor dash:AutoCompleteEditor ;
            dash:nillable true ;
            dash:viewer dash:LabelViewer ;
            sh:class :Absorber_Role_Player ;
            sh:description "The entity that takes in or absorbs something."@en ;
            sh:group :RolesPropertyGroup ;
            sh:minCount 1 ;
            sh:name "absorber"@en ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path :absorber ],
        [ dash:editor dash:AutoCompleteEditor ;
            dash:nillable true ;
            dash:viewer dash:LabelViewer ;
            sh:class :Substance_Role_Player ;
            sh:description "The entity, material, or information that is taken in or absorbed."@en ;
            sh:group :RolesPropertyGroup ;
            sh:minCount 1 ;
            sh:name "substance"@en ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path :substance ],
        [ dash:editor dash:AutoCompleteEditor ;
            dash:viewer dash:LabelViewer ;
            sh:class :Origin_Role_Player ;
            sh:description "The physical or figurative starting location of the focal object."@en ;
            sh:group :RolesPropertyGroup ;
            sh:name "origin"@en ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path :origin ] ;
    sh:rule [ a sh:SPARQLRule ;
            sh:construct """
        PREFIX : <https://falcontologist.github.io/shacl-demo/ontology/>
        PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
        
        CONSTRUCT {
            ?absorber ?opaqueProperty ?substance .
            ?absorber ?propFrom ?origin .
        }
        WHERE {
            ?this a :Absorb ;
                  :lemma ?lemma ;
                  :synset ?synset ;
                  :substance ?substance .
            
            ?lemmaNode :lemma ?lemma ;
                       :present3sg ?verbForm .
            
            BIND(SHA256(CONCAT(?lemma, "|", ?synset)) AS ?hash)
            BIND(SUBSTR(STR(?hash), 1, 12) AS ?hashSub)
            
            OPTIONAL { 
                ?this :absorber ?absorber . 
                BIND(IRI(CONCAT(STR(:), ?verbForm, "_", ?hashSub)) AS ?opaqueProperty)
            }
            
            OPTIONAL {
                ?this :absorber ?absorber ;
                      :origin ?origin .
                
                OPTIONAL { ?substance rdfs:label ?subLabel . }
                BIND(COALESCE(?subLabel, REPLACE(STR(?substance), "^.*[/#]", "")) AS ?rawSubName)
                BIND(LCASE(REPLACE(?rawSubName, " ", "_")) AS ?subName)
                
                BIND(IRI(CONCAT(STR(:), ?verbForm, "_", ?subName, "_from_", ?hashSub)) AS ?propFrom)
            }
        }
        """ ;
            sh:order 6 ] ;
    sh:targetClass :Absorb .

:Acquisition_Inference_Rule a sh:NodeShape ;
    sh:rule [ a sh:SPARQLRule ;
            sh:construct """
            PREFIX : <https://falcontologist.github.io/shacl-demo/ontology/>
            CONSTRUCT { ?agent :acquires ?target . }
            WHERE {
                ?this :acquirer ?agent .
                ?this :acquisition ?target .
            }
        """ ;
            sh:order 1 ;
            sh:prefixes :Ontology_Prefixes ] ;
    sh:targetClass :Acquisition .

:Acquisition_shape a sh:NodeShape,
        :Situation_shape ;
    rdfs:label "Acquisition (shape)"@en ;
    dash:defaultViewForRole dash:all ;
    skos:example "Alphabet acquires Wiz for 32 Billion USD."@en ;
    sh:description "A situation where an entity acquires another entity, often for a specific financial cost."@en ;
    sh:property [ dash:editor dash:AutoCompleteEditor ;
            dash:nillable true ;
            dash:viewer dash:LabelViewer ;
            sh:class :Acquirer_Role_Player ;
            sh:description "The entity performing the acquisition."@en ;
            sh:group :RolesPropertyGroup ;
            sh:minCount 1 ;
            sh:name "acquirer"@en ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path :acquirer ],
        [ dash:editor dash:AutoCompleteEditor ;
            dash:nillable true ;
            dash:viewer dash:LabelViewer ;
            sh:class :Target_Role_Player ;
            sh:description "The entity being acquired."@en ;
            sh:group :RolesPropertyGroup ;
            sh:minCount 1 ;
            sh:name "target"@en ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path :target ],
        [ dash:editor dash:DetailsEditor ;
            dash:viewer dash:DetailsViewer ;
            sh:description "The financial cost, value, or price associated with the situation."@en ;
            sh:group :RolesPropertyGroup ;
            sh:minCount 1 ;
            sh:name "cost"@en ;
            sh:nodeKind sh:BlankNode ;
            sh:or ( [ sh:node :Cost_shape ] [ sh:class :Unknown_Entity ] ) ;
            sh:order 3 ;
            sh:path :cost ] ;
    sh:rule [ a sh:SPARQLRule ;
            sh:construct """
        PREFIX : <https://falcontologist.github.io/shacl-demo/ontology/>
        PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
        
        CONSTRUCT {
            ?acquirer ?opaqueProperty ?target .
            ?acquirer ?propFor ?costString .
        }
        WHERE {
            ?this a :Acquisition ;
                  :lemma ?lemma ;
                  :synset ?synset ;
                  :acquirer ?acquirer ;
                  :target ?target .
            
            # Look up the proper 3ps inflection from the lemma node
            ?lemmaNode :lemma ?lemma ;
                       :present3sg ?verbForm .
            
            BIND(SHA256(CONCAT(?lemma, "|", ?synset)) AS ?hash)
            BIND(SUBSTR(STR(?hash), 1, 12) AS ?hashSub)
            
            # Inference 1: <acquirer> <acquires> <target>
            BIND(IRI(CONCAT(STR(:), ?verbForm, "_", ?hashSub)) AS ?opaqueProperty)
            
            # Inference 2: <acquirer> <acquires_target_for> "Value Multiplier Unit"
            OPTIONAL {
                ?this :cost ?costNode .
                ?costNode :value ?value ;
                          :unit ?unitNode .
                
                # Format Unit label
                OPTIONAL { ?unitNode rdfs:label ?unitLabel . }
                BIND(COALESCE(?unitLabel, REPLACE(STR(?unitNode), "^.*[/#]", "")) AS ?uLabel)
                
                # Format Multiplier label (Optional)
                OPTIONAL { 
                    ?costNode :multiplier ?multiplierNode . 
                    OPTIONAL { ?multiplierNode rdfs:label ?multiplierLabel . }
                    BIND(COALESCE(?multiplierLabel, REPLACE(STR(?multiplierNode), "^.*[/#]", "")) AS ?mLabel)
                }
                
                # Concatenate literal
                BIND(IF(BOUND(?mLabel), CONCAT(STR(?value), " ", STR(?mLabel), " ", STR(?uLabel)), CONCAT(STR(?value), " ", STR(?uLabel))) AS ?costString)
                
                # Format Target for predicate
                OPTIONAL { ?target rdfs:label ?targetLabel . }
                BIND(COALESCE(?targetLabel, REPLACE(STR(?target), "^.*[/#]", "")) AS ?rawTargetName)
                BIND(LCASE(REPLACE(?rawTargetName, " ", "_")) AS ?targetName)
                
                BIND(IRI(CONCAT(STR(:), ?verbForm, "_", ?targetName, "_for_", ?hashSub)) AS ?propFor)
            }
        }
        """ ;
            sh:order 6 ] ;
    sh:targetClass :Acquisition .

:Action_shape a sh:NodeShape,
        :Situation_shape ;
    rdfs:label "Action (shape)"@en ;
    dash:defaultViewForRole dash:all ;
    skos:example "Uber disrupts the taxi service industry."@en ;
    sh:description "A situation where an actor performs an action directed at a target."@en ;
    sh:property [ dash:editor dash:AutoCompleteEditor ;
            dash:nillable true ;
            dash:viewer dash:LabelViewer ;
            sh:class :Actor_Role_Player ;
            sh:description "The entity performing the action."@en ;
            sh:group :RolesPropertyGroup ;
            sh:minCount 1 ;
            sh:name "actor"@en ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path :actor ],
        [ dash:editor dash:AutoCompleteEditor ;
            dash:viewer dash:LabelViewer ;
            sh:class :Implement_Role_Player ;
            sh:description "An entity used to carry out the action (e.g., a weapon, tool, or vehicle)."@en ;
            sh:group :RolesPropertyGroup ;
            sh:name "implement"@en ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path :implement ],
        [ dash:editor dash:AutoCompleteEditor ;
            dash:nillable true ;
            dash:viewer dash:LabelViewer ;
            sh:class :Target_Role_Player ;
            sh:description "The entity that is the target of the action."@en ;
            sh:group :RolesPropertyGroup ;
            sh:minCount 1 ;
            sh:name "target"@en ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path :target ],
        [ dash:editor dash:AutoCompleteEditor ;
            dash:viewer dash:LabelViewer ;
            sh:class :Action_Role_Player ;
            sh:description "The volitional situation being performed."@en ;
            sh:group :RolesPropertyGroup ;
            sh:name "action"@en ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path :action ],
        [ dash:editor dash:AutoCompleteEditor ;
            dash:viewer dash:LabelViewer ;
            sh:class :Manner_Role_Player ;
            sh:description "The way or style in which the action occurs."@en ;
            sh:group :RolesPropertyGroup ;
            sh:name "manner"@en ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path :manner ] ;
    sh:rule [ a sh:SPARQLRule ;
            sh:construct """
        PREFIX : <https://falcontologist.github.io/shacl-demo/ontology/>
        
        CONSTRUCT {
            ?actor ?opaqueProperty ?target .
            ?actor ?propPerforms ?action .
        }
        WHERE {
            ?this a :Action ;
                  :lemma ?lemma ;
                  :synset ?synset ;
                  :actor ?actor ;
                  :target ?target .
            
            # Look up the proper 3ps inflection from the lemma node
            ?lemmaNode :lemma ?lemma ;
                       :present3sg ?verbForm .
            
            BIND(SHA256(CONCAT(?lemma, "|", ?synset)) AS ?hash)
            BIND(SUBSTR(STR(?hash), 1, 12) AS ?hashSub)
            
            # Inference 1: <actor> <lemma x inflection> <target>
            BIND(IRI(CONCAT(STR(:), ?verbForm, "_", ?hashSub)) AS ?opaqueProperty)
            
            # Inference 2: <actor> <performs> <action>
            OPTIONAL {
                ?this :action ?action .
                BIND(IRI(CONCAT(STR(:), "performs_", ?hashSub)) AS ?propPerforms)
            }
        }
        """ ;
            sh:order 8 ] ;
    sh:targetClass :Action .

:Advising_shape a sh:NodeShape,
        :Situation_shape ;
    rdfs:label "Advising (shape)"@en ;
    dash:defaultViewForRole dash:all ;
    skos:example "McKinsey advises the government on economic policy."@en ;
    sh:description "A situation where an adviser provides advice or guidance to an advisee."@en ;
    sh:property [ dash:editor dash:AutoCompleteEditor ;
            dash:nillable true ;
            dash:viewer dash:LabelViewer ;
            sh:class :Adviser_Role_Player ;
            sh:description "The entity providing the advice or guidance."@en ;
            sh:group :RolesPropertyGroup ;
            sh:minCount 1 ;
            sh:name "adviser"@en ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path :adviser ],
        [ sh:class :Advice_Role_Player ;
            sh:description "The message of counsel conveyed by the adviser."@en ;
            sh:group :RolesPropertyGroup ;
            sh:name "advice"@en ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path :advice ],
        [ dash:editor dash:AutoCompleteEditor ;
            dash:nillable true ;
            dash:viewer dash:LabelViewer ;
            sh:class :Advisee_Role_Player ;
            sh:description "The entity receiving the advice or guidance."@en ;
            sh:group :RolesPropertyGroup ;
            sh:minCount 1 ;
            sh:name "advisee"@en ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path :advisee ],
        [ dash:editor dash:AutoCompleteEditor ;
            dash:nillable true ;
            dash:viewer dash:LabelViewer ;
            sh:class :Industry_Role_Player ;
            sh:description "The sector or field of commercial or professional activity."@en ;
            sh:group :RolesPropertyGroup ;
            sh:name "industry"@en ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path :industry ],
        [ dash:editor dash:AutoCompleteEditor ;
            dash:viewer dash:LabelViewer ;
            sh:class :Topic_Role_Player ;
            sh:description "The subject matter of the communication."@en ;
            sh:group :RolesPropertyGroup ;
            sh:name "topic"@en ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path :topic ] ;
    sh:rule [ a sh:SPARQLRule ;
            sh:construct """
        PREFIX : <https://falcontologist.github.io/shacl-demo/ontology/>
        
        CONSTRUCT {
            ?adviser ?opaqueProperty ?advisee .
            ?adviser ?propOn ?topic .
            ?adviser ?propIn ?industry .
        }
        WHERE {
            ?this a :Advising ;
                  :lemma ?lemma ;
                  :synset ?synset ;
                  :adviser ?adviser .
            
            # Look up the proper 3ps inflection from the lemma node
            ?lemmaNode :lemma ?lemma ;
                       :present3sg ?verbForm .
            
            BIND(SHA256(CONCAT(?lemma, "|", ?synset)) AS ?hash)
            BIND(SUBSTR(STR(?hash), 1, 12) AS ?hashSub)
            
            # Inference 1: <adviser> <advises> <advisee>
            OPTIONAL {
                ?this :advisee ?advisee .
                BIND(IRI(CONCAT(STR(:), ?verbForm, "_", ?hashSub)) AS ?opaqueProperty)
            }
            
            # Inference 2: <adviser> <advises_on> <topic>
            OPTIONAL {
                ?this :topic ?topic .
                BIND(IRI(CONCAT(STR(:), ?verbForm, "_on_", ?hashSub)) AS ?propOn)
            }

            # Inference 3: <adviser> <advises_in> <industry>
            OPTIONAL {
                ?this :industry ?industry .
                BIND(IRI(CONCAT(STR(:), ?verbForm, "_in_", ?hashSub)) AS ?propIn)
            }
        }
        """ ;
            sh:order 8 ] ;
    sh:targetClass :Advising .

:Affect_shape a sh:NodeShape,
        :Situation_shape ;
    rdfs:label "Affect (shape)"@en ;
    dash:defaultViewForRole dash:all ;
    skos:example "Supply chain disruptions affect the automotive industry."@en ;
    sh:description "A situation where an affecter produces an effect or change upon an affectee."@en ;
    sh:property [ dash:editor dash:AutoCompleteEditor ;
            dash:nillable true ;
            dash:viewer dash:LabelViewer ;
            sh:class :Affecter_Role_Player ;
            sh:description "The entity or situation that produces an effect."@en ;
            sh:group :RolesPropertyGroup ;
            sh:minCount 1 ;
            sh:name "affecter"@en ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path :affecter ],
        [ dash:editor dash:AutoCompleteEditor ;
            dash:nillable true ;
            dash:viewer dash:LabelViewer ;
            sh:class :Affectee_Role_Player ;
            sh:description "The entity or situation that is influenced or changed."@en ;
            sh:group :RolesPropertyGroup ;
            sh:minCount 1 ;
            sh:name "affectee"@en ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path :affectee ],
        [ dash:editor dash:AutoCompleteEditor ;
            dash:viewer dash:LabelViewer ;
            sh:class :Situation ;
            sh:description "The resulting state or situation triggered by the effect."@en ;
            sh:group :RolesPropertyGroup ;
            sh:name "reaction"@en ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path :reaction ] ;
    sh:rule [ a sh:SPARQLRule ;
            sh:construct """
        PREFIX : <https://falcontologist.github.io/shacl-demo/ontology/>
        
        CONSTRUCT {
            ?affecter ?opaqueProperty ?affectee .
            ?affectee ?propReaction ?reaction .
        }
        WHERE {
            ?this a :Affect ;
                  :lemma ?lemma ;
                  :synset ?synset .
            
            # Look up the proper 3ps inflection from the lemma node
            ?lemmaNode :lemma ?lemma ;
                       :present3sg ?verbForm .
            
            BIND(SHA256(CONCAT(?lemma, "|", ?synset)) AS ?hash)
            BIND(SUBSTR(STR(?hash), 1, 12) AS ?hashSub)
            
            # Core Relation: <affecter> <affects> <affectee>
            OPTIONAL {
                ?this :affecter ?affecter ;
                      :affectee ?affectee .
                BIND(IRI(CONCAT(STR(:), ?verbForm, "_", ?hashSub)) AS ?opaqueProperty)
            }

            # Causal Reaction: <affectee> <results_in> <reaction>
            OPTIONAL {
                ?this :affectee ?affectee ;
                      :reaction ?reaction .
                BIND(IRI(CONCAT(STR(:), "results_in_", ?hashSub)) AS ?propReaction)
            }
        }
        """ ;
            sh:order 6 ] ;
    sh:targetClass :Affect .

:Affiliation_shape a sh:NodeShape,
        :Situation_shape ;
    rdfs:label "Affiliation (shape)"@en ;
    dash:defaultViewForRole dash:all ;
    skos:example "Bloomberg hires Data Management Professionals."@en ;
    sh:description "A situation where an affiliator causes a participant to become affiliated or unaffiliated with a social institution in some role or activity, or away from some location of origin, or toward some destination."@en ;
    sh:property [ dash:editor dash:AutoCompleteEditor ;
            dash:viewer dash:LabelViewer ;
            sh:class :Destination_Role_Player ;
            sh:description "The target location or state the participant arrives at."@en ;
            sh:group :RolesPropertyGroup ;
            sh:name "destination"@en ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path :destination ],
        [ dash:editor dash:AutoCompleteEditor ;
            dash:viewer dash:LabelViewer ;
            sh:class :Institution_Role_Player ;
            sh:description "The group or organization the participant is affiliated with."@en ;
            sh:group :RolesPropertyGroup ;
            sh:name "institution"@en ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path :institution ],
        [ dash:editor dash:AutoCompleteEditor ;
            dash:viewer dash:LabelViewer ;
            sh:class :Situation ;
            sh:description "The resulting state or situation triggered by the affiliation."@en ;
            sh:group :RolesPropertyGroup ;
            sh:name "result"@en ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path :result ],
        [ dash:editor dash:AutoCompleteEditor ;
            dash:viewer dash:LabelViewer ;
            sh:class :Occupation_Entity ;
            sh:description "The capacity or title assumed by the participant."@en ;
            sh:group :RolesPropertyGroup ;
            sh:name "role"@en ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path :role ],
        [ dash:editor dash:AutoCompleteEditor ;
            dash:nillable true ;
            dash:viewer dash:LabelViewer ;
            sh:class :Affiliator_Role_Player ;
            sh:description "The entity that causes the affiliation or change in status."@en ;
            sh:group :RolesPropertyGroup ;
            sh:minCount 1 ;
            sh:name "affiliator"@en ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path :affiliator ],
        [ dash:editor dash:AutoCompleteEditor ;
            dash:viewer dash:LabelViewer ;
            sh:class :Rite_Role_Player ;
            sh:description "An event, ceremony, or document acting as the instrument of affiliation."@en ;
            sh:group :RolesPropertyGroup ;
            sh:name "rite"@en ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path :rite ],
        [ dash:editor dash:AutoCompleteEditor ;
            dash:nillable true ;
            dash:viewer dash:LabelViewer ;
            sh:class :Participant_Role_Player ;
            sh:description "The entity whose membership or status is being changed."@en ;
            sh:group :RolesPropertyGroup ;
            sh:minCount 1 ;
            sh:name "participant"@en ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path :participant ],
        [ dash:editor dash:AutoCompleteEditor ;
            dash:viewer dash:LabelViewer ;
            sh:class :Situation ;
            sh:description "A specific duty or activity assigned to the participant."@en ;
            sh:group :RolesPropertyGroup ;
            sh:name "task"@en ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path :task ],
        [ dash:editor dash:AutoCompleteEditor ;
            dash:viewer dash:LabelViewer ;
            sh:class :Origin_Role_Player ;
            sh:description "The source location or group the participant is leaving."@en ;
            sh:group :RolesPropertyGroup ;
            sh:name "origin"@en ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path :origin ],
        [ dash:editor dash:AutoCompleteEditor ;
            dash:viewer dash:LabelViewer ;
            sh:class :Trajectory_Role_Player ;
            sh:description "The path or route taken during the change of affiliation."@en ;
            sh:group :RolesPropertyGroup ;
            sh:name "trajectory"@en ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path :trajectory ] ;
    sh:rule [ a sh:SPARQLRule ;
            sh:construct """
        PREFIX : <https://falcontologist.github.io/shacl-demo/ontology/>
        PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
        
        CONSTRUCT {
            ?affiliator ?opaqueProperty ?participant .
            ?affiliator ?propFrom ?origin .
            ?affiliator ?propInto ?institution .
            ?affiliator ?propAs ?role .
            ?affiliator ?propTo ?destination .
        }
        WHERE {
            ?this a :Affiliation ;
                  :lemma ?lemma ;
                  :synset ?synset ;
                  :affiliator ?affiliator ;
                  :participant ?participant .
            
            # Look up the proper 3ps inflection from the lemma node
            ?lemmaNode :lemma ?lemma ;
                       :present3sg ?verbForm .
            
            BIND(SHA256(CONCAT(?lemma, "|", ?synset)) AS ?hash)
            BIND(SUBSTR(STR(?hash), 1, 12) AS ?hashSub)
            
            # Extract the participant name for dynamic predicates
            OPTIONAL { ?participant rdfs:label ?pLabel . }
            BIND(COALESCE(?pLabel, REPLACE(STR(?participant), "^.*[/#]", "")) AS ?rawPName)
            BIND(LCASE(REPLACE(?rawPName, " ", "_")) AS ?pName)
            
            # Inference 1: <affiliator> <verb x inflection> <participant>
            BIND(IRI(CONCAT(STR(:), ?verbForm, "_", ?hashSub)) AS ?opaqueProperty)
            
            # Inference 2: <affiliator> <verb_participant_from> <origin>
            OPTIONAL {
                ?this :origin ?origin .
                BIND(IRI(CONCAT(STR(:), ?verbForm, "_", ?pName, "_from_", ?hashSub)) AS ?propFrom)
            }
            
            # Inference 3: <affiliator> <verb_participant_into> <institution>
            OPTIONAL {
                ?this :institution ?institution .
                BIND(IRI(CONCAT(STR(:), ?verbForm, "_", ?pName, "_into_", ?hashSub)) AS ?propInto)
            }

            # Inference 4: <affiliator> <verb_participant_as> <role>
            OPTIONAL {
                ?this :role ?role .
                BIND(IRI(CONCAT(STR(:), ?verbForm, "_", ?pName, "_as_", ?hashSub)) AS ?propAs)
            }

            # Inference 5: <affiliator> <verb_participant_to> <destination>
            OPTIONAL {
                ?this :destination ?destination .
                BIND(IRI(CONCAT(STR(:), ?verbForm, "_", ?pName, "_to_", ?hashSub)) AS ?propTo)
            }
        }
        """ ;
            sh:order 13 ] ;
    sh:targetClass :Affiliation .

:Announcement_shape a sh:NodeShape,
        :Situation_shape ;
    rdfs:label "Announcement (shape)"@en ;
    dash:defaultViewForRole dash:all ;
    skos:example "JP Morgan Chase announces the acquisition of First Republic Bank."@en ;
    sh:description "A situation in which an announcer produces a signal that conveys a meaningful message."@en ;
    sh:property [ dash:editor dash:AutoCompleteEditor ;
            dash:nillable true ;
            dash:viewer dash:LabelViewer ;
            sh:class :Announcer_Role_Player ;
            sh:description "The entity making the announcement."@en ;
            sh:group :RolesPropertyGroup ;
            sh:minCount 1 ;
            sh:name "announcer"@en ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path :announcer ],
        [ dash:editor dash:AutoCompleteEditor ;
            dash:viewer dash:LabelViewer ;
            sh:class :Signal_Role_Player ;
            sh:description "The medium or signal produced to convey the message."@en ;
            sh:group :RolesPropertyGroup ;
            sh:name "signal"@en ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path :signal ],
        [ dash:editor dash:AutoCompleteEditor ;
            dash:nillable true ;
            dash:viewer dash:LabelViewer ;
            sh:class :Announcement_Role_Player ;
            sh:description "The core message or situation being conveyed."@en ;
            sh:group :RolesPropertyGroup ;
            sh:minCount 1 ;
            sh:name "announcement"@en ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path :announcement ],
        [ dash:editor dash:AutoCompleteEditor ;
            dash:viewer dash:LabelViewer ;
            sh:class :Addressee_Role_Player ;
            sh:description "The entity to whom the announcement is directed."@en ;
            sh:group :RolesPropertyGroup ;
            sh:name "addressee"@en ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path :addressee ],
        [ dash:editor dash:AutoCompleteEditor ;
            dash:viewer dash:LabelViewer ;
            sh:class :Topic_Role_Player ;
            sh:description "The subject matter of the communication."@en ;
            sh:group :RolesPropertyGroup ;
            sh:name "topic"@en ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path :topic ],
        [ dash:editor dash:AutoCompleteEditor ;
            dash:viewer dash:LabelViewer ;
            sh:class :Characterization_Role_Player ;
            sh:description "How the focal point is characterized or evaluated."@en ;
            sh:group :RolesPropertyGroup ;
            sh:name "characterization"@en ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path :characterization ],
        [ dash:editor dash:AutoCompleteEditor ;
            dash:viewer dash:LabelViewer ;
            sh:class :Manner_Role_Player ;
            sh:description "The way or style in which the announcement occurs."@en ;
            sh:group :RolesPropertyGroup ;
            sh:name "manner"@en ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path :manner ] ;
    sh:rule [ a sh:SPARQLRule ;
            sh:construct """
        PREFIX : <https://falcontologist.github.io/shacl-demo/ontology/>
        PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
        
        CONSTRUCT {
            ?announcer ?opaqueProperty ?announcement .
            ?announcer ?propTo ?addressee .
            ?announcer ?propAbout ?topic .
        }
        WHERE {
            ?this a :Announcement ;
                  :lemma ?lemma ;
                  :synset ?synset ;
                  :announcer ?announcer ;
                  :announcement ?announcement .
            
            # Look up the proper 3ps inflection from the lemma node
            ?lemmaNode :lemma ?lemma ;
                       :present3sg ?verbForm .
            
            BIND(SHA256(CONCAT(?lemma, "|", ?synset)) AS ?hash)
            BIND(SUBSTR(STR(?hash), 1, 12) AS ?hashSub)
            
            # Extract the announcement name for dynamic predicates
            OPTIONAL { ?announcement rdfs:label ?annLabel . }
            BIND(COALESCE(?annLabel, REPLACE(STR(?announcement), "^.*[/#]", "")) AS ?rawAnnName)
            BIND(LCASE(REPLACE(?rawAnnName, " ", "_")) AS ?annName)
            
            # Inference 1: <announcer> <verb x inflection> <announcement>
            BIND(IRI(CONCAT(STR(:), ?verbForm, "_", ?hashSub)) AS ?opaqueProperty)
            
            # Inference 2: <announcer> <verb_announcement_to> <addressee>
            OPTIONAL {
                ?this :addressee ?addressee .
                BIND(IRI(CONCAT(STR(:), ?verbForm, "_", ?annName, "_to_", ?hashSub)) AS ?propTo)
            }
            
            # Inference 3: <announcer> <verb_announcement_about> <topic>
            OPTIONAL {
                ?this :topic ?topic .
                BIND(IRI(CONCAT(STR(:), ?verbForm, "_", ?annName, "_about_", ?hashSub)) AS ?propAbout)
            }
        }
        """ ;
            sh:order 10 ] ;
    sh:targetClass :Announcement .

:Association_shape a sh:NodeShape,
        :Situation_shape ;
    rdfs:label "Association (shape)"@en ;
    dash:defaultViewForRole dash:all ;
    sh:description "A situation where a conceptual association is drawn between exactly two items, in terms of some attribute."@en ;
    sh:property [ dash:editor dash:AutoCompleteEditor ;
            dash:viewer dash:LabelViewer ;
            sh:class :Item_Role_Player ;
            sh:description "The entities that are being conceptually associated with each other (requires exactly two)."@en ;
            sh:group :RolesPropertyGroup ;
            sh:maxCount 2 ;
            sh:minCount 2 ;
            sh:name "item"@en ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path :item ],
        [ dash:editor dash:AutoCompleteEditor ;
            dash:viewer dash:LabelViewer ;
            sh:class :Attribute_Role_Player ;
            sh:description "The specific feature, quality, or context that forms the basis of the association."@en ;
            sh:group :RolesPropertyGroup ;
            sh:name "attribute"@en ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path :attribute ] ;
    sh:rule [ a sh:SPARQLRule ;
            sh:construct """
    PREFIX : <https://falcontologist.github.io/shacl-demo/ontology/>
    
    CONSTRUCT {
        ?item1 ?opaqueProperty ?item2 .
    }
    WHERE {
        ?this a :Association ;
              :lemma ?lemma ;
              :synset ?synset ;
              :item ?item1, ?item2 .
              
        # Ensure we are capturing the two distinct items
        FILTER(?item1 != ?item2)
        
        # Look up the proper 3ps inflection from the lemma node
        ?lemmaNode :lemma ?lemma ;
                   :present3sg ?verbForm .
        
        # Construct the property URI combining the verb form and 'with'
        BIND(SHA256(CONCAT(?lemma, "|", ?synset)) AS ?hash)
        BIND(IRI(CONCAT(STR(:), ?verbForm, "_with_", SUBSTR(STR(?hash), 1, 12))) AS ?opaqueProperty)
    }
    """ ;
            sh:order 5 ] ;
    sh:targetClass :Association .

