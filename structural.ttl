:Cost_shape a sh:NodeShape ;
    rdfs:label "Cost (shape)"@en ;
    sh:description "A representation of financial magnitude, value, or price associated with an evaluation, obligation, or transaction."@en ;
    sh:property [ dash:editor dash:TextFieldEditor ;
            dash:viewer dash:LiteralViewer ;
            sh:description "The numerical value of the magnitude or quantity."@en ;
            sh:minCount 1 ;
            sh:name "value"@en ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:or ( [ sh:datatype xsd:decimal ] [ sh:class :Unknown_Entity ] ) ;
            sh:order 1 ;
            sh:path :value ],
        [ dash:editor dash:AutoCompleteEditor ;
            dash:viewer dash:LabelViewer ;
            sh:class :Multiplier_Role_Player ;
            sh:description "A factor applied to the numerical value to express the true magnitude (e.g., Million, Billion)."@en ;
            sh:name "multiplier"@en ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path :multiplier ],
        [ dash:editor dash:AutoCompleteEditor ;
            dash:nillable true ;
            dash:viewer dash:LabelViewer ;
            sh:class :Unit_Role_Player ;
            sh:description "The standard of measurement or currency in which the value is expressed."@en ;
            sh:minCount 1 ;
            sh:name "unit"@en ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path :unit ],
        [ dash:viewer dash:LiteralViewer ;
            sh:description "The time when the event or state began."@en ;
            sh:name "start"@en ;
            sh:nodeKind sh:Literal ;
            sh:or ( [ sh:datatype xsd:date ] [ sh:datatype xsd:gYearMonth ] [ sh:datatype xsd:gYear ] ) ;
            sh:order 4 ;
            sh:path :start ],
        [ dash:viewer dash:LiteralViewer ;
            sh:description "The time when the event or state ended."@en ;
            sh:name "end"@en ;
            sh:nodeKind sh:Literal ;
            sh:or ( [ sh:datatype xsd:date ] [ sh:datatype xsd:gYearMonth ] [ sh:datatype xsd:gYear ] ) ;
            sh:order 5 ;
            sh:path :end ] .

:Physical a :Realm ;
    rdfs:label "Physical"@en .

:Social a :Realm ;
    rdfs:label "Social"@en .

:absorber a rdf:Property ;
    rdfs:label "absorber"@en ;
    rdfs:subPropertyOf :transformer .

:substance a rdf:Property ;
    rdfs:label "substance"@en ;
    rdfs:subPropertyOf :product,
        :theme .

:Ontology_Prefixes sh:declare [ sh:namespace "https://falcontologist.github.io/shacl-demo/ontology/"^^xsd:anyURI ;
            sh:prefix "" ],
        [ sh:namespace "http://www.w3.org/1999/02/22-rdf-syntax-ns#"^^xsd:anyURI ;
            sh:prefix "rdf" ],
        [ sh:namespace "http://www.w3.org/2000/01/rdf-schema#"^^xsd:anyURI ;
            sh:prefix "rdfs" ],
        [ sh:namespace "http://www.w3.org/2001/XMLSchema#"^^xsd:anyURI ;
            sh:prefix "xsd" ] .

:TemporalPropertyGroup a sh:PropertyGroup ;
    rdfs:label "Temporal"@en ;
    sh:order 1.0 .

:Situation_shape a sh:NodeShape,
        :Situation_shape ;
    rdfs:label "Situation (shape)"@en ;
    dash:defaultViewForRole dash:all ;
    sh:property [ dash:editor dash:DatePickerEditor ;
            dash:viewer dash:LiteralViewer ;
            sh:description "The time when the event or state began."@en ;
            sh:group :TemporalPropertyGroup ;
            sh:name "start"@en ;
            sh:nodeKind sh:Literal ;
            sh:or ( [ sh:datatype xsd:date ] [ sh:datatype xsd:gYearMonth ] [ sh:datatype xsd:gYear ] ) ;
            sh:order 98.0 ;
            sh:path :start ],
        [ dash:editor dash:DatePickerEditor ;
            dash:viewer dash:LiteralViewer ;
            sh:description "The time when the event or state ended."@en ;
            sh:group :TemporalPropertyGroup ;
            sh:name "end"@en ;
            sh:nodeKind sh:Literal ;
            sh:or ( [ sh:datatype xsd:date ] [ sh:datatype xsd:gYearMonth ] [ sh:datatype xsd:gYear ] ) ;
            sh:order 99.0 ;
            sh:path :end ] .

:RolesPropertyGroup a sh:PropertyGroup ;
    rdfs:label "Roles"@en ;
    sh:order 0.0 .

