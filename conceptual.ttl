### ENTITY CLASSES ###

:Group a rdfs:Class ; 
    rdfs:label "Group"@en ;
    :semantic_domain :Group ;
    rdfs:subClassOf :Entity .

:Person a rdfs:Class ; 
    rdfs:label "Person"@en ;
    :semantic_domain :Person ;
    rdfs:subClassOf :Entity .

:Location a rdfs:Class ; 
    rdfs:label "Place"@en ;
    :semantic_domain :Location ;
    rdfs:subClassOf :Entity .

:Quantity_Dimension a rdfs:Class ; 
    rdfs:label "Quantity Dimension"@en ;
    :semantic_domain :Evaluation ;
    rdfs:subClassOf :Entity .

:Quality_Dimension a rdfs:Class ; 
    rdfs:label "Quality Dimension"@en ;
    :semantic_domain :Evaluation ;
    rdfs:subClassOf :Entity .

:Time a rdfs:Class ; 
    rdfs:label "Time"@en ;
    :semantic_domain :Time ;
    rdfs:subClassOf :Entity .

### ROOT AND STRUCTURAL PROPERTIES ###

:shape_element a rdf:Property ;
    rdfs:label "shape element"@en ;
    rdfs:comment "The root superproperty for all semantic role and modifier properties ."@en .

:proto_role a rdf:Property ;
    rdfs:label "proto-role"@en ;
    rdfs:comment "Superproperty for all proto-role properties ."@en ;
    rdfs:subPropertyOf :shape_element .

:modifier a rdf:Property ;
    rdfs:label "modifier"@en ;
    rdfs:comment "Superproperty for all modifier properties ."@en ;
    rdfs:subPropertyOf :shape_element .

### PROTO-ROLES ###

:proto_agent a rdf:Property ;
    rdfs:label "proto-agent"@en ;
    rdfs:comment "Proto-role for initiator/agent participants ."@en ;
    rdfs:subPropertyOf :proto_role .

:proto_instrument a rdf:Property ;
    rdfs:label "proto-instrument"@en ;
    rdfs:comment "Proto-role for resource/instrument participants ."@en ;
    rdfs:subPropertyOf :proto_role .

:proto_patient a rdf:Property ;
    rdfs:label "proto-patient"@en ;
    rdfs:comment "Proto-role for essence/patient participants ."@en ;
    rdfs:subPropertyOf :proto_role .

:proto_source a rdf:Property ;
    rdfs:label "proto-source"@en ;
    rdfs:comment "Proto-role for source-oriented participants (stub for future expansion) ."@en ;
    rdfs:subPropertyOf :proto_role .

:proto_path a rdf:Property ;
    rdfs:label "proto-path"@en ;
    rdfs:comment "Proto-role for path-oriented participants (stub for future expansion) ."@en ;
    rdfs:subPropertyOf :proto_role .

:proto_goal a rdf:Property ;
    rdfs:label "proto-goal"@en ;
    rdfs:comment "Proto-role for goal-oriented participants ."@en ;
    rdfs:subPropertyOf :proto_role .

### Basic Roles (Ring 3) ###

:agonist a rdf:Property ;
    rdfs:label "agonist"@en ;
    rdfs:subPropertyOf :proto_patient ;
    rdfs:domain :Force ;
    rdfs:range :Agonist_Role_Player .

:antagonist a rdf:Property ;
    rdfs:label "antagonist"@en ;
    rdfs:subPropertyOf :proto_agent ;
    rdfs:domain :Force ;
    rdfs:range :Antagonist_Role_Player .

:means a rdf:Property ;
    rdfs:label "means"@en ;
    rdfs:subPropertyOf :proto_instrument ;
    rdfs:domain :Force ;
    rdfs:range :Means_Role_Player .

