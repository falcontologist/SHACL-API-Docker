:Employment_shape a :Situation_shape, sh:NodeShape ;
    rdfs:label "Employment (shape)"@en ;
    sh:description "A situation where an employee engages in an occupation or activity for an employer in an industry."@en ;
    skos:example "Christina Montgomery works as Vice President at IBM."@en ;
    
    sh:property [ 
        sh:name "employer"@en ; 
        sh:description "The organization, person, or geopolitical entity providing employment."@en ;
        sh:nodeKind sh:BlankNodeOrIRI ; 
        sh:path :employer ;
        sh:minCount 1 ;
        sh:order 1 ;
        dash:editor dash:AutoCompleteEditor ;
        dash:viewer dash:LabelViewer ;
        sh:or (
            [ sh:class :Organization_Entity ]
            [ sh:class :Geopolitical_Entity ]
            [ sh:class :Person_Entity ]
            [ sh:class :Unknown_Entity ]
        )
    ] ;
    
    sh:property [ 
        sh:name "employee"@en ; 
        sh:description "The person who engages in the employment."@en ;
        sh:nodeKind sh:BlankNodeOrIRI ; 
        sh:path :employee ;
        sh:minCount 1 ;
        sh:order 2 ;
        dash:editor dash:AutoCompleteEditor ;
        dash:viewer dash:LabelViewer ;
        sh:or (
            [ sh:class :Person_Entity ]
            [ sh:class :Unknown_Entity ]
        )
    ] ;
    
    sh:property [ 
        sh:name "occupation"@en ; 
        sh:description "The specific job title or role held by the employee."@en ;
        sh:nodeKind sh:BlankNodeOrIRI ; 
        sh:path :occupation ;
        sh:class :Occupation_Entity ;
        sh:order 3 ;
        dash:editor dash:AutoCompleteEditor ;
        dash:viewer dash:LabelViewer 
    ] ;

    sh:property [ 
        sh:name "industry"@en ; 
        sh:description "The sector or field of commercial or professional activity."@en ;
        sh:nodeKind sh:BlankNodeOrIRI ; 
        sh:path :industry ;
        sh:class :Industry_Entity ;
        sh:order 4 ;
        dash:editor dash:AutoCompleteEditor ;
        dash:viewer dash:LabelViewer 
    ] ;

    sh:property [ 
        sh:name "location"@en ; 
        sh:description "The geographical location of the employment, or Remote."@en ;
        sh:nodeKind sh:BlankNodeOrIRI ; 
        sh:path :location ;
        sh:order 5 ;
        dash:editor dash:AutoCompleteEditor ;
        dash:viewer dash:LabelViewer ;
        sh:or (
            [ sh:class :Geopolitical_Entity ]
            [ sh:hasValue :Remote ]
        )
    ] ;

    sh:property [ 
        sh:name "start"@en ; 
        sh:description "The time when the event or state began."@en ;
        sh:path :start ; 
        sh:order 6 ;
        dash:viewer dash:LiteralViewer ;
        sh:or (
            [ sh:datatype xsd:date ]
            [ sh:datatype xsd:gYearMonth ]
            [ sh:datatype xsd:gYear ]
        )
    ] ;
    
    sh:property [ 
        sh:name "end"@en ; 
        sh:description "The time when the event or state ended."@en ;
        sh:path :end ; 
        sh:order 7 ;
        dash:viewer dash:LiteralViewer ;
        sh:or (
            [ sh:datatype xsd:date ]
            [ sh:datatype xsd:gYearMonth ]
            [ sh:datatype xsd:gYear ]
        )
    ] ;
    
    sh:rule [ a sh:SPARQLRule ;
            sh:construct """
        PREFIX : <https://falcontologist.github.io/shacl-demo/ontology/>
        
        CONSTRUCT {
            ?employee ?propAt ?employer .
            ?employee ?propAsA ?occupation .
            ?employee ?propIn ?industry .
        }
        WHERE {
            ?this a :Employment ;
                  :lemma ?lemmaNode ;
                  :synset ?synsetNode ;
                  :employee ?employee .
            
            # Look up the literal string and verb form
            ?lemmaNode :lemma ?lemmaString ;
                       :present3sg ?verbForm .
            
            # Generate the base hash just once
            BIND(SHA256(CONCAT(?lemmaString, "|", STR(?synsetNode))) AS ?hash)
            BIND(SUBSTR(STR(?hash), 1, 12) AS ?hashSub)
            
            # Conditionally match employer and bind the "_at_" property
            OPTIONAL {
                ?this :employer ?employer .
                BIND(IRI(CONCAT(STR(:), ?verbForm, "_at_", ?hashSub)) AS ?propAt)
            }
            
            # Conditionally match occupation and bind the "_as_a_" property
            OPTIONAL {
                ?this :occupation ?occupation .
                BIND(IRI(CONCAT(STR(:), ?verbForm, "_as_a_", ?hashSub)) AS ?propAsA)
            }
            
            # Conditionally match industry and bind the "_in_" property
            OPTIONAL {
                ?this :industry ?industry .
                BIND(IRI(CONCAT(STR(:), ?verbForm, "_in_", ?hashSub)) AS ?propIn)
            }
        }
        """ ;
            sh:order 2 ] ;
    sh:targetClass :Employment .

