### additional classes and properties: move to conceptual.ttl

### classes

:Substance_Entity a rdfs:Class, sh:NodeShape ;
    rdfs:label "Substance Entity"@en .

:Information_Entity a rdfs:Class, sh:NodeShape ;
    rdfs:label "Information Entity"@en .

:Manner_Entity a rdfs:Class, sh:NodeShape ;
    rdfs:label "Manner Entity"@en .

:Numerical_Multiplier_Entity a rdfs:Class, sh:NodeShape ;
    rdfs:label "Numerical Multiplier Entity"@en .

:Unit_Entity a rdfs:Class, sh:NodeShape ;
    rdfs:label "Unit Entity"@en .

:Unknown_Entity a rdfs:Class, sh:NodeShape ;
    rdfs:label "Unknown Entity"@en ;
    sh:description "An existential placeholder for a required role where the specific entity or value is unknown or undisclosed."@en .

### properties

:substance a rdf:Property ;
    rdfs:subPropertyOf :theme, :product ;
    rdfs:label "substance"@en .

:absorber a rdf:Property ;
    rdfs:subPropertyOf :transformer ;
    rdfs:label "absorber"@en .

### shapes

# =============================================================================
# Situation Shapes — Affordance Feature Targeting
#
# Roles target marker superclasses instead of enumerating entity classes.
#
#   sh:class :Volitional_Entity   — pulls Person, Organization, GPE
#   sh:class :Physical_Entity     — pulls Person, Organism, Location, GPE,
#                                    Substance, Food, Product
#   sh:class :Locative_Entity     — pulls Location, GPE
#
# For conjunctions: multiple sh:class on the same property (SHACL ANDs them).
# For disjunctions: sh:or with sh:class alternatives.
# =============================================================================

:Absorption_shape a :Situation_shape, sh:NodeShape ;
    rdfs:label "Absorption (shape)"@en ;
    sh:description "A situation where an entity takes in, incorporates, or assimilates another entity or substance."@en ;
    skos:example "More than 7.4 million people with diabetes take insulin every year."@en ;
    
    sh:property [ 
        sh:name "absorber"@en ; 
        sh:description "The entity that takes in or absorbs something."@en ;
        sh:nodeKind sh:BlankNodeOrIRI ; 
        sh:path :absorber ;
        sh:minCount 1 ;
        sh:order 1 ;
        dash:editor dash:AutoCompleteEditor ;
        dash:viewer dash:LabelViewer ;
        # Volitional agents OR physical containers/locations
        sh:or (
            [ sh:class :Volitional_Entity ]
            [ sh:class :Physical_Entity ]
            [ sh:class :Unknown_Entity ]
        )
    ] ;
    
    sh:property [ 
        sh:name "substance"@en ; 
        sh:description "The entity, substance, or information that is taken in or absorbed."@en ;
        sh:nodeKind sh:BlankNodeOrIRI ; 
        sh:path :substance ;
        sh:minCount 1 ;
        sh:order 2 ;
        dash:editor dash:AutoCompleteEditor ;
        dash:viewer dash:LabelViewer ;
        # Physical matter OR symbolic content
        sh:or (
            [ sh:class :Physical_Entity ]
            [ sh:class :Symbolic_Entity ]
            [ sh:class :Unknown_Entity ]
        )
    ] ;

    sh:property [ 
        sh:name "origin"@en ; 
        sh:description "The source or starting location of the substance before it was absorbed."@en ;
        sh:nodeKind sh:BlankNodeOrIRI ; 
        sh:path :origin ;
        sh:order 3 ;
        dash:editor dash:AutoCompleteEditor ;
        dash:viewer dash:LabelViewer ;
        # Spatial source
        sh:class :Locative_Entity
    ] ;

    sh:property [ 
        sh:name "start"@en ; 
        sh:description "The time when the event or state began."@en ;
        sh:path :start ; 
        sh:order 4 ;
        dash:viewer dash:LiteralViewer ;
        sh:or (
            [ sh:datatype xsd:date ]
            [ sh:datatype xsd:gYearMonth ]
            [ sh:datatype xsd:gYear ]
        )
    ] ;
    
    sh:property [ 
        sh:name "end"@en ; 
        sh:description "The time when the event or state ended."@en ;
        sh:path :end ; 
        sh:order 5 ;
        dash:viewer dash:LiteralViewer ;
        sh:or (
            [ sh:datatype xsd:date ]
            [ sh:datatype xsd:gYearMonth ]
            [ sh:datatype xsd:gYear ]
        )
    ] ;
    
    sh:rule [ a sh:SPARQLRule ;
            sh:construct """
        PREFIX : <https://falcontologist.github.io/shacl-demo/ontology/>
        PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
        CONSTRUCT {
            ?absorber ?opaqueProperty ?substance .
            ?absorber ?propFrom ?origin .
        }
        WHERE {
            ?this a :Absorption ; :lemma ?lemma ; :synset ?synset ; :substance ?substance .
            ?lemmaNode :lemma ?lemma ; :present3sg ?verbForm .
            BIND(SHA256(CONCAT(?lemma, "|", ?synset)) AS ?hash)
            BIND(SUBSTR(STR(?hash), 1, 12) AS ?hashSub)
            OPTIONAL { 
                ?this :absorber ?absorber . 
                BIND(IRI(CONCAT(STR(:), ?verbForm, "_", ?hashSub)) AS ?opaqueProperty)
            }
            OPTIONAL {
                ?this :absorber ?absorber ; :origin ?origin .
                OPTIONAL { ?substance rdfs:label ?subLabel . }
                BIND(COALESCE(?subLabel, REPLACE(STR(?substance), "^.*[/#]", "")) AS ?rawSubName)
                BIND(LCASE(REPLACE(?rawSubName, " ", "_")) AS ?subName)
                BIND(IRI(CONCAT(STR(:), ?verbForm, "_", ?subName, "_from_", ?hashSub)) AS ?propFrom)
            }
        }
        """ ;
            sh:order 2 ] ;
    sh:targetClass :Absorption .


:Acquisition_shape a :Situation_shape, sh:NodeShape ;
    rdfs:label "Acquisition (shape)"@en ;
    sh:description "A situation where an entity acquires another entity, often for a specific financial cost."@en ;
    skos:example "Alphabet acquires Wiz for 32 Billion USD."@en ;
    
    sh:property [ 
        sh:name "acquirer"@en ; 
        sh:description "The entity performing the acquisition."@en ;
        sh:nodeKind sh:BlankNodeOrIRI ; 
        sh:path :acquirer ;
        sh:minCount 1 ;
        sh:order 1 ;
        dash:editor dash:AutoCompleteEditor ;
        dash:viewer dash:LabelViewer ;
        # Volitional agents
        sh:or (
            [ sh:class :Volitional_Entity ]
            [ sh:class :Unknown_Entity ]
        )
    ] ;
    
    sh:property [ 
        sh:name "target"@en ; 
        sh:description "The entity being acquired."@en ;
        sh:nodeKind sh:BlankNodeOrIRI ; 
        sh:path :target ;
        sh:minCount 1 ;
        sh:order 2 ;
        dash:editor dash:AutoCompleteEditor ;
        dash:viewer dash:LabelViewer ;
        # Anything discrete that can be owned
        sh:or (
            [ sh:class :Bounded_Entity ]
            [ sh:class :Unknown_Entity ]
        )
    ] ;

    sh:property [ 
        sh:name "cost"@en ; 
        sh:description "The financial cost, value, or price associated with the situation."@en ;
        sh:nodeKind sh:BlankNode ; 
        sh:path :cost ;
        sh:minCount 1 ;
        sh:order 3 ;
        dash:editor dash:DetailsEditor ;
        dash:viewer dash:DetailsViewer ;
        sh:or (
            [ sh:node :Cost_shape ]
            [ sh:class :Unknown_Entity ]
        )
    ] ;

    sh:property [ 
        sh:name "start"@en ; 
        sh:path :start ; sh:order 4 ;
        dash:viewer dash:LiteralViewer ;
        sh:or ( [ sh:datatype xsd:date ] [ sh:datatype xsd:gYearMonth ] [ sh:datatype xsd:gYear ] )
    ] ;
    sh:property [ 
        sh:name "end"@en ; 
        sh:path :end ; sh:order 5 ;
        dash:viewer dash:LiteralViewer ;
        sh:or ( [ sh:datatype xsd:date ] [ sh:datatype xsd:gYearMonth ] [ sh:datatype xsd:gYear ] )
    ] ;
    
    sh:rule [ a sh:SPARQLRule ;
            sh:construct """
        PREFIX : <https://falcontologist.github.io/shacl-demo/ontology/>
        PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
        CONSTRUCT {
            ?acquirer ?opaqueProperty ?target .
            ?acquirer ?propFor ?costString .
        }
        WHERE {
            ?this a :Acquisition ; :lemma ?lemma ; :synset ?synset ; :acquirer ?acquirer ; :target ?target .
            ?lemmaNode :lemma ?lemma ; :present3sg ?verbForm .
            BIND(SHA256(CONCAT(?lemma, "|", ?synset)) AS ?hash)
            BIND(SUBSTR(STR(?hash), 1, 12) AS ?hashSub)
            BIND(IRI(CONCAT(STR(:), ?verbForm, "_", ?hashSub)) AS ?opaqueProperty)
            OPTIONAL {
                ?this :cost ?costNode .
                ?costNode :value ?value ; :unit ?unitNode .
                OPTIONAL { ?unitNode rdfs:label ?unitLabel . }
                BIND(COALESCE(?unitLabel, REPLACE(STR(?unitNode), "^.*[/#]", "")) AS ?uLabel)
                OPTIONAL { ?costNode :multiplier ?multiplierNode . 
                    OPTIONAL { ?multiplierNode rdfs:label ?multiplierLabel . }
                    BIND(COALESCE(?multiplierLabel, REPLACE(STR(?multiplierNode), "^.*[/#]", "")) AS ?mLabel) }
                BIND(IF(BOUND(?mLabel), CONCAT(STR(?value), " ", STR(?mLabel), " ", STR(?uLabel)), CONCAT(STR(?value), " ", STR(?uLabel))) AS ?costString)
                OPTIONAL { ?target rdfs:label ?targetLabel . }
                BIND(COALESCE(?targetLabel, REPLACE(STR(?target), "^.*[/#]", "")) AS ?rawTargetName)
                BIND(LCASE(REPLACE(?rawTargetName, " ", "_")) AS ?targetName)
                BIND(IRI(CONCAT(STR(:), ?verbForm, "_", ?targetName, "_for_", ?hashSub)) AS ?propFor)
            }
        }
        """ ;
            sh:order 2 ] ;
    sh:targetClass :Acquisition .


:Action_shape a :Situation_shape, sh:NodeShape ;
    rdfs:label "Action (shape)"@en ;
    sh:description "A situation where an actor performs an action directed at a target."@en ;
    skos:example "Uber disrupts the taxi service industry."@en ;
    
    sh:property [ 
        sh:name "actor"@en ; 
        sh:description "The entity performing the action."@en ;
        sh:nodeKind sh:BlankNodeOrIRI ; 
        sh:path :actor ;
        sh:minCount 1 ;
        sh:order 1 ;
        dash:editor dash:AutoCompleteEditor ;
        dash:viewer dash:LabelViewer ;
        # Volitional agents
        sh:or (
            [ sh:class :Volitional_Entity ]
            [ sh:class :Unknown_Entity ]
        )
    ] ;

    sh:property [ 
        sh:name "implement"@en ; 
        sh:description "An entity used to carry out the action (e.g., a weapon, tool, or vehicle)."@en ;
        sh:nodeKind sh:BlankNodeOrIRI ; 
        sh:path :implement ;
        sh:order 2 ;
        dash:editor dash:AutoCompleteEditor ;
        dash:viewer dash:LabelViewer ;
        # Purposeful tools OR raw physical means
        sh:or (
            [ sh:class :Telic_Entity ]
            [ sh:class :Physical_Entity ]
        )
    ] ;
    
    sh:property [ 
        sh:name "target"@en ; 
        sh:description "The entity that is the target of the action."@en ;
        sh:nodeKind sh:BlankNodeOrIRI ; 
        sh:path :target ;
        sh:minCount 1 ;
        sh:order 3 ;
        dash:editor dash:AutoCompleteEditor ;
        dash:viewer dash:LabelViewer ;
        # Anything individuated
        sh:or (
            [ sh:class :Bounded_Entity ]
            [ sh:class :Unknown_Entity ]
        )
    ] ;

    sh:property [ 
        sh:name "action"@en ; 
        sh:description "The volitional situation being performed."@en ;
        sh:nodeKind sh:BlankNodeOrIRI ; 
        sh:path :action ;
        sh:class :Situation ;
        sh:order 4 ;
        dash:editor dash:AutoCompleteEditor ;
        dash:viewer dash:LabelViewer 
    ] ;

    sh:property [ 
        sh:name "manner"@en ; 
        sh:description "The way or style in which the action occurs."@en ;
        sh:nodeKind sh:BlankNodeOrIRI ; 
        sh:path :manner ;
        sh:class :Manner_Entity ;
        sh:order 5 ;
        dash:editor dash:AutoCompleteEditor ;
        dash:viewer dash:LabelViewer 
    ] ;

    sh:property [ 
        sh:name "start"@en ; 
        sh:path :start ; sh:order 6 ;
        dash:viewer dash:LiteralViewer ;
        sh:or ( [ sh:datatype xsd:date ] [ sh:datatype xsd:gYearMonth ] [ sh:datatype xsd:gYear ] )
    ] ;
    sh:property [ 
        sh:name "end"@en ; 
        sh:path :end ; sh:order 7 ;
        dash:viewer dash:LiteralViewer ;
        sh:or ( [ sh:datatype xsd:date ] [ sh:datatype xsd:gYearMonth ] [ sh:datatype xsd:gYear ] )
    ] ;
    
    sh:rule [ a sh:SPARQLRule ;
            sh:construct """
        PREFIX : <https://falcontologist.github.io/shacl-demo/ontology/>
        CONSTRUCT { ?actor ?opaqueProperty ?target . ?actor ?propPerforms ?action . }
        WHERE {
            ?this a :Action ; :lemma ?lemma ; :synset ?synset ; :actor ?actor ; :target ?target .
            ?lemmaNode :lemma ?lemma ; :present3sg ?verbForm .
            BIND(SHA256(CONCAT(?lemma, "|", ?synset)) AS ?hash)
            BIND(SUBSTR(STR(?hash), 1, 12) AS ?hashSub)
            BIND(IRI(CONCAT(STR(:), ?verbForm, "_", ?hashSub)) AS ?opaqueProperty)
            OPTIONAL { ?this :action ?action .
                BIND(IRI(CONCAT(STR(:), "performs_", ?hashSub)) AS ?propPerforms) }
        }
        """ ;
            sh:order 2 ] ;
    sh:targetClass :Action .


:Advising_shape a :Situation_shape, sh:NodeShape ;
    rdfs:label "Advising (shape)"@en ;
    sh:description "A situation where an adviser provides advice or guidance to an advisee."@en ;
    skos:example "McKinsey advises the government on economic policy."@en ;
    
    sh:property [ 
        sh:name "adviser"@en ; 
        sh:description "The entity providing the advice or guidance."@en ;
        sh:nodeKind sh:BlankNodeOrIRI ; 
        sh:path :adviser ;
        sh:minCount 1 ;
        sh:order 1 ;
        dash:editor dash:AutoCompleteEditor ;
        dash:viewer dash:LabelViewer ;
        sh:or (
            [ sh:class :Volitional_Entity ]
            [ sh:class :Unknown_Entity ]
        )
    ] ;

    sh:property [ 
        sh:name "advice"@en ; 
        sh:description "The message of counsel conveyed by the adviser."@en ;
        sh:path :advice ;
        sh:order 2 ;
        sh:or (
            [ sh:nodeKind sh:IRI ; dash:editor dash:AutoCompleteEditor ; dash:viewer dash:LabelViewer ]
            [ sh:nodeKind sh:Literal ; dash:editor dash:TextAreaEditor ; dash:viewer dash:LiteralViewer ]
        )
    ] ;
    
    sh:property [ 
        sh:name "advisee"@en ; 
        sh:description "The entity receiving the advice or guidance."@en ;
        sh:nodeKind sh:BlankNodeOrIRI ; 
        sh:path :advisee ;
        sh:minCount 1 ;
        sh:order 3 ;
        dash:editor dash:AutoCompleteEditor ;
        dash:viewer dash:LabelViewer ;
        # Must be capable of understanding advice
        sh:or (
            [ sh:class :Volitional_Entity ]
            [ sh:class :Unknown_Entity ]
        )
    ] ;

    sh:property [ 
        sh:name "topic"@en ; 
        sh:description "The situation or subject matter being advised upon."@en ;
        sh:nodeKind sh:BlankNodeOrIRI ; 
        sh:path :topic ;
        sh:class :Situation ;
        sh:order 4 ;
        dash:editor dash:AutoCompleteEditor ;
        dash:viewer dash:LabelViewer 
    ] ;

    sh:property [ 
        sh:name "industry"@en ; 
        sh:description "The sector or field of commercial or professional activity."@en ;
        sh:nodeKind sh:BlankNodeOrIRI ; 
        sh:path :industry ;
        sh:class :Industry_Entity ;
        sh:order 5 ;
        dash:editor dash:AutoCompleteEditor ;
        dash:viewer dash:LabelViewer 
    ] ;

    sh:property [ 
        sh:name "start"@en ; 
        sh:path :start ; sh:order 6 ;
        dash:viewer dash:LiteralViewer ;
        sh:or ( [ sh:datatype xsd:date ] [ sh:datatype xsd:gYearMonth ] [ sh:datatype xsd:gYear ] )
    ] ;
    sh:property [ 
        sh:name "end"@en ; 
        sh:path :end ; sh:order 7 ;
        dash:viewer dash:LiteralViewer ;
        sh:or ( [ sh:datatype xsd:date ] [ sh:datatype xsd:gYearMonth ] [ sh:datatype xsd:gYear ] )
    ] ;
    
    sh:rule [ a sh:SPARQLRule ;
            sh:construct """
        PREFIX : <https://falcontologist.github.io/shacl-demo/ontology/>
        CONSTRUCT { ?adviser ?opaqueProperty ?advisee . ?adviser ?propOn ?topic . ?adviser ?propIn ?industry . }
        WHERE {
            ?this a :Advising ; :lemma ?lemma ; :synset ?synset ; :adviser ?adviser .
            ?lemmaNode :lemma ?lemma ; :present3sg ?verbForm .
            BIND(SHA256(CONCAT(?lemma, "|", ?synset)) AS ?hash)
            BIND(SUBSTR(STR(?hash), 1, 12) AS ?hashSub)
            OPTIONAL { ?this :advisee ?advisee .
                BIND(IRI(CONCAT(STR(:), ?verbForm, "_", ?hashSub)) AS ?opaqueProperty) }
            OPTIONAL { ?this :topic ?topic .
                BIND(IRI(CONCAT(STR(:), ?verbForm, "_on_", ?hashSub)) AS ?propOn) }
            OPTIONAL { ?this :industry ?industry .
                BIND(IRI(CONCAT(STR(:), ?verbForm, "_in_", ?hashSub)) AS ?propIn) }
        }
        """ ;
            sh:order 2 ] ;
    sh:targetClass :Advising .


:Affect_shape a :Situation_shape, sh:NodeShape ;
    rdfs:label "Affect (shape)"@en ;
    sh:description "A situation where an affecter produces an effect or change upon an affectee."@en ;
    skos:example "Supply chain disruptions affect the automotive industry."@en ;
    
    sh:property [ 
        sh:name "affecter"@en ; 
        sh:description "The entity or situation that produces an effect."@en ;
        sh:nodeKind sh:BlankNodeOrIRI ; 
        sh:path :affecter ;
        sh:minCount 1 ;
        sh:order 1 ;
        dash:editor dash:AutoCompleteEditor ;
        dash:viewer dash:LabelViewer ;
        # Broadest causal: volitional, symbolic, or dynamic entities, or situations
        sh:or (
            [ sh:class :Volitional_Entity ]
            [ sh:class :Symbolic_Entity ]
            [ sh:class :Dynamic_Entity ]
            [ sh:class :Situation ]
            [ sh:class :Unknown_Entity ]
        )
    ] ;
    
    sh:property [ 
        sh:name "affectee"@en ; 
        sh:description "The entity or situation that is influenced or changed."@en ;
        sh:nodeKind sh:BlankNodeOrIRI ; 
        sh:path :affectee ;
        sh:minCount 1 ;
        sh:order 2 ;
        dash:editor dash:AutoCompleteEditor ;
        dash:viewer dash:LabelViewer ;
        # Anything individuated, or situations
        sh:or (
            [ sh:class :Bounded_Entity ]
            [ sh:class :Situation ]
            [ sh:class :Unknown_Entity ]
        )
    ] ;

    sh:property [ 
        sh:name "reaction"@en ; 
        sh:description "The resulting state or situation triggered by the effect."@en ;
        sh:nodeKind sh:BlankNodeOrIRI ; 
        sh:path :reaction ;
        sh:class :Situation ;
        sh:order 3 ;
        dash:editor dash:AutoCompleteEditor ;
        dash:viewer dash:LabelViewer 
    ] ;

    sh:property [ 
        sh:name "start"@en ; 
        sh:path :start ; sh:order 4 ;
        dash:viewer dash:LiteralViewer ;
        sh:or ( [ sh:datatype xsd:date ] [ sh:datatype xsd:gYearMonth ] [ sh:datatype xsd:gYear ] )
    ] ;
    sh:property [ 
        sh:name "end"@en ; 
        sh:path :end ; sh:order 5 ;
        dash:viewer dash:LiteralViewer ;
        sh:or ( [ sh:datatype xsd:date ] [ sh:datatype xsd:gYearMonth ] [ sh:datatype xsd:gYear ] )
    ] ;
    
    sh:rule [ a sh:SPARQLRule ;
            sh:construct """
        PREFIX : <https://falcontologist.github.io/shacl-demo/ontology/>
        CONSTRUCT { ?affecter ?opaqueProperty ?affectee . ?affectee ?propReaction ?reaction . }
        WHERE {
            ?this a :Affect ; :lemma ?lemma ; :synset ?synset .
            ?lemmaNode :lemma ?lemma ; :present3sg ?verbForm .
            BIND(SHA256(CONCAT(?lemma, "|", ?synset)) AS ?hash)
            BIND(SUBSTR(STR(?hash), 1, 12) AS ?hashSub)
            OPTIONAL { ?this :affecter ?affecter ; :affectee ?affectee .
                BIND(IRI(CONCAT(STR(:), ?verbForm, "_", ?hashSub)) AS ?opaqueProperty) }
            OPTIONAL { ?this :affectee ?affectee ; :reaction ?reaction .
                BIND(IRI(CONCAT(STR(:), "results_in_", ?hashSub)) AS ?propReaction) }
        }
        """ ;
            sh:order 2 ] ;
    sh:targetClass :Affect .


:Affiliation_shape a :Situation_shape, sh:NodeShape ;
    rdfs:label "Affiliation (shape)"@en ;
    sh:description "A situation where an affiliator causes a participant to become affiliated or unaffiliated with a social institution in some role or activity, or away from some location of origin, or toward some destination."@en ;
    skos:example "Bloomberg hires Data Management Professionals."@en ;
    
    sh:property [ 
        sh:name "affiliator"@en ; 
        sh:description "The entity that causes the affiliation or change in status."@en ;
        sh:nodeKind sh:BlankNodeOrIRI ; 
        sh:path :affiliator ;
        sh:minCount 1 ;
        sh:order 1 ;
        dash:editor dash:AutoCompleteEditor ;
        dash:viewer dash:LabelViewer ;
        sh:or (
            [ sh:class :Volitional_Entity ]
            [ sh:class :Unknown_Entity ]
        )
    ] ;

    sh:property [ 
        sh:name "rite"@en ; 
        sh:description "An event, ceremony, or document acting as the instrument of affiliation."@en ;
        sh:nodeKind sh:BlankNodeOrIRI ; 
        sh:path :rite ;
        sh:order 2 ;
        dash:editor dash:AutoCompleteEditor ;
        dash:viewer dash:LabelViewer ;
        sh:or (
            [ sh:class :Situation ]
            [ sh:class :Symbolic_Entity ]
        )
    ] ;
    
    sh:property [ 
        sh:name "participant"@en ; 
        sh:description "The entity whose membership or status is being changed."@en ;
        sh:nodeKind sh:BlankNodeOrIRI ; 
        sh:path :participant ;
        sh:minCount 1 ;
        sh:order 3 ;
        dash:editor dash:AutoCompleteEditor ;
        dash:viewer dash:LabelViewer ;
        # Must be volitional (can participate socially)
        sh:or (
            [ sh:class :Volitional_Entity ]
            [ sh:class :Unknown_Entity ]
        )
    ] ;

    sh:property [ 
        sh:name "institution"@en ; 
        sh:description "The group or organization the participant is affiliated with."@en ;
        sh:nodeKind sh:BlankNodeOrIRI ; 
        sh:path :institution ;
        sh:order 4 ;
        dash:editor dash:AutoCompleteEditor ;
        dash:viewer dash:LabelViewer ;
        # Institutional social constructs (ORG, GPE)
        sh:class :Institutional_Entity
    ] ;

    sh:property [ 
        sh:name "role"@en ; 
        sh:description "The capacity or title assumed by the participant."@en ;
        sh:nodeKind sh:BlankNodeOrIRI ; 
        sh:path :role ;
        sh:order 5 ;
        dash:editor dash:AutoCompleteEditor ;
        dash:viewer dash:LabelViewer ;
        # Scalar institutional functional position
        sh:class :Scalar_Entity ;
        sh:class :Institutional_Entity ;
        sh:class :Telic_Entity
    ] ;

    sh:property [ 
        sh:name "task"@en ; 
        sh:description "A specific duty or activity assigned to the participant."@en ;
        sh:nodeKind sh:BlankNodeOrIRI ; 
        sh:path :task ;
        sh:class :Situation ;
        sh:order 6 ;
        dash:editor dash:AutoCompleteEditor ;
        dash:viewer dash:LabelViewer 
    ] ;

    sh:property [ 
        sh:name "result"@en ; 
        sh:description "The resulting situation triggered by the affiliation."@en ;
        sh:nodeKind sh:BlankNodeOrIRI ; 
        sh:path :result ;
        sh:class :Situation ;
        sh:order 7 ;
        dash:editor dash:AutoCompleteEditor ;
        dash:viewer dash:LabelViewer 
    ] ;

    sh:property [ 
        sh:name "origin"@en ; 
        sh:description "The source location or group the participant is leaving."@en ;
        sh:nodeKind sh:BlankNodeOrIRI ; 
        sh:path :origin ;
        sh:order 8 ;
        dash:editor dash:AutoCompleteEditor ;
        dash:viewer dash:LabelViewer ;
        # Can leave a place OR an institution
        sh:or (
            [ sh:class :Locative_Entity ]
            [ sh:class :Institutional_Entity ]
        )
    ] ;

    sh:property [ 
        sh:name "trajectory"@en ; 
        sh:description "The path or route taken during the change of affiliation."@en ;
        sh:nodeKind sh:BlankNodeOrIRI ; 
        sh:path :trajectory ;
        sh:order 9 ;
        dash:editor dash:AutoCompleteEditor ;
        dash:viewer dash:LabelViewer ;
        sh:class :Locative_Entity
    ] ;

    sh:property [ 
        sh:name "destination"@en ; 
        sh:description "The target location or state the participant arrives at."@en ;
        sh:nodeKind sh:BlankNodeOrIRI ; 
        sh:path :destination ;
        sh:order 10 ;
        dash:editor dash:AutoCompleteEditor ;
        dash:viewer dash:LabelViewer ;
        # Can arrive at a place OR join an institution
        sh:or (
            [ sh:class :Locative_Entity ]
            [ sh:class :Institutional_Entity ]
        )
    ] ;

    sh:property [ 
        sh:name "start"@en ; 
        sh:path :start ; sh:order 11 ;
        dash:viewer dash:LiteralViewer ;
        sh:or ( [ sh:datatype xsd:date ] [ sh:datatype xsd:gYearMonth ] [ sh:datatype xsd:gYear ] )
    ] ;
    sh:property [ 
        sh:name "end"@en ; 
        sh:path :end ; sh:order 12 ;
        dash:viewer dash:LiteralViewer ;
        sh:or ( [ sh:datatype xsd:date ] [ sh:datatype xsd:gYearMonth ] [ sh:datatype xsd:gYear ] )
    ] ;
    
    sh:rule [ a sh:SPARQLRule ;
            sh:construct """
        PREFIX : <https://falcontologist.github.io/shacl-demo/ontology/>
        PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
        CONSTRUCT {
            ?affiliator ?opaqueProperty ?participant .
            ?affiliator ?propFrom ?origin .
            ?affiliator ?propInto ?institution .
            ?affiliator ?propAs ?role .
            ?affiliator ?propTo ?destination .
        }
        WHERE {
            ?this a :Affiliation ; :lemma ?lemma ; :synset ?synset ;
                  :affiliator ?affiliator ; :participant ?participant .
            ?lemmaNode :lemma ?lemma ; :present3sg ?verbForm .
            BIND(SHA256(CONCAT(?lemma, "|", ?synset)) AS ?hash)
            BIND(SUBSTR(STR(?hash), 1, 12) AS ?hashSub)
            OPTIONAL { ?participant rdfs:label ?pLabel . }
            BIND(COALESCE(?pLabel, REPLACE(STR(?participant), "^.*[/#]", "")) AS ?rawPName)
            BIND(LCASE(REPLACE(?rawPName, " ", "_")) AS ?pName)
            BIND(IRI(CONCAT(STR(:), ?verbForm, "_", ?hashSub)) AS ?opaqueProperty)
            OPTIONAL { ?this :origin ?origin .
                BIND(IRI(CONCAT(STR(:), ?verbForm, "_", ?pName, "_from_", ?hashSub)) AS ?propFrom) }
            OPTIONAL { ?this :institution ?institution .
                BIND(IRI(CONCAT(STR(:), ?verbForm, "_", ?pName, "_into_", ?hashSub)) AS ?propInto) }
            OPTIONAL { ?this :role ?role .
                BIND(IRI(CONCAT(STR(:), ?verbForm, "_", ?pName, "_as_", ?hashSub)) AS ?propAs) }
            OPTIONAL { ?this :destination ?destination .
                BIND(IRI(CONCAT(STR(:), ?verbForm, "_", ?pName, "_to_", ?hashSub)) AS ?propTo) }
        }
        """ ;
            sh:order 2 ] ;
    sh:targetClass :Affiliation .

### ---

:Announcement_shape a :Situation_shape, sh:NodeShape ;
    rdfs:label "Announcement (shape)"@en ;
    sh:description "A situation where an announcer produces a signal that conveys a meaningful message."@en ;
    skos:example "JP Morgan Chase announces the acquisition of First Republic Bank."@en ;
    
    sh:property [ 
        sh:name "announcer"@en ; 
        sh:description "The entity making the announcement."@en ;
        sh:nodeKind sh:BlankNodeOrIRI ; 
        sh:path :announcer ;
        sh:minCount 1 ;
        sh:order 1 ;
        dash:editor dash:AutoCompleteEditor ;
        dash:viewer dash:LabelViewer ;
        sh:or (
            [ sh:class :Person_Entity ]
            [ sh:class :Organization_Entity ]
            [ sh:class :Geopolitical_Entity ]
            [ sh:class :Unknown_Entity ]
        )
    ] ;

    sh:property [ 
        sh:name "signal"@en ; 
        sh:description "The medium or signal produced to convey the message."@en ;
        sh:nodeKind sh:BlankNodeOrIRI ; 
        sh:path :signal ;
        sh:order 2 ;
        dash:editor dash:AutoCompleteEditor ;
        dash:viewer dash:LabelViewer ;
        sh:or (
            [ sh:class :Information_Entity ]
            [ sh:class :Situation ]
        )
    ] ;
    
    sh:property [ 
        sh:name "addressee"@en ; 
        sh:description "The entity to whom the announcement is directed."@en ;
        sh:nodeKind sh:BlankNodeOrIRI ; 
        sh:path :addressee ;
        sh:order 3 ;
        dash:editor dash:AutoCompleteEditor ;
        dash:viewer dash:LabelViewer ;
        sh:or (
            [ sh:class :Person_Entity ]
            [ sh:class :Organization_Entity ]
            [ sh:class :Geopolitical_Entity ]
        )
    ] ;

    sh:property [ 
        sh:name "announcement"@en ; 
        sh:description "The core message or situation being conveyed."@en ;
        sh:nodeKind sh:BlankNodeOrIRI ; 
        sh:path :announcement ;
        sh:minCount 1 ;
        sh:order 4 ;
        dash:editor dash:AutoCompleteEditor ;
        dash:viewer dash:LabelViewer ;
        sh:or (
            [ sh:class :Situation ]
            [ sh:class :Information_Entity ]
            [ sh:class :Unknown_Entity ]
        )
    ] ;

    sh:property [ 
        sh:name "topic"@en ; 
        sh:description "The subject matter of the announcement."@en ;
        sh:nodeKind sh:BlankNodeOrIRI ; 
        sh:path :topic ;
        sh:order 5 ;
        dash:editor dash:AutoCompleteEditor ;
        dash:viewer dash:LabelViewer ;
        sh:or (
            [ sh:class :Situation ]
            [ sh:class :Information_Entity ]
        )
    ] ;

    sh:property [ 
        sh:name "characterization"@en ; 
        sh:description "How the announcement is characterized or evaluated."@en ;
        sh:nodeKind sh:BlankNodeOrIRI ; 
        sh:path :characterization ;
        sh:class :Information_Entity ;
        sh:order 6 ;
        dash:editor dash:AutoCompleteEditor ;
        dash:viewer dash:LabelViewer 
    ] ;

    sh:property [ 
        sh:name "manner"@en ; 
        sh:description "The way or style in which the announcement occurs."@en ;
        sh:nodeKind sh:BlankNodeOrIRI ; 
        sh:path :manner ;
        sh:class :Manner_Entity ;
        sh:order 7 ;
        dash:editor dash:AutoCompleteEditor ;
        dash:viewer dash:LabelViewer 
    ] ;

    sh:property [ 
        sh:name "start"@en ; 
        sh:description "The time when the event or state began."@en ;
        sh:path :start ; 
        sh:order 8 ;
        dash:viewer dash:LiteralViewer ;
        sh:or (
            [ sh:datatype xsd:date ]
            [ sh:datatype xsd:gYearMonth ]
            [ sh:datatype xsd:gYear ]
        )
    ] ;
    
    sh:property [ 
        sh:name "end"@en ; 
        sh:description "The time when the event or state ended."@en ;
        sh:path :end ; 
        sh:order 9 ;
        dash:viewer dash:LiteralViewer ;
        sh:or (
            [ sh:datatype xsd:date ]
            [ sh:datatype xsd:gYearMonth ]
            [ sh:datatype xsd:gYear ]
        )
    ] ;
    
    sh:rule [ a sh:SPARQLRule ;
            sh:construct """
        PREFIX : <https://falcontologist.github.io/shacl-demo/ontology/>
        PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
        
        CONSTRUCT {
            ?announcer ?opaqueProperty ?announcement .
            ?announcer ?propTo ?addressee .
            ?announcer ?propAbout ?topic .
        }
        WHERE {
            ?this a :Announcement ;
                  :lemma ?lemma ;
                  :synset ?synset ;
                  :announcer ?announcer ;
                  :announcement ?announcement .
            
            # Look up the proper 3ps inflection from the lemma node
            ?lemmaNode :lemma ?lemma ;
                       :present3sg ?verbForm .
            
            BIND(SHA256(CONCAT(?lemma, "|", ?synset)) AS ?hash)
            BIND(SUBSTR(STR(?hash), 1, 12) AS ?hashSub)
            
            # Extract the announcement name for dynamic predicates
            OPTIONAL { ?announcement rdfs:label ?annLabel . }
            BIND(COALESCE(?annLabel, REPLACE(STR(?announcement), "^.*[/#]", "")) AS ?rawAnnName)
            BIND(LCASE(REPLACE(?rawAnnName, " ", "_")) AS ?annName)
            
            # Inference 1: <announcer> <verb x inflection> <announcement>
            BIND(IRI(CONCAT(STR(:), ?verbForm, "_", ?hashSub)) AS ?opaqueProperty)
            
            # Inference 2: <announcer> <verb_announcement_to> <addressee>
            OPTIONAL {
                ?this :addressee ?addressee .
                BIND(IRI(CONCAT(STR(:), ?verbForm, "_", ?annName, "_to_", ?hashSub)) AS ?propTo)
            }
            
            # Inference 3: <announcer> <verb_announcement_about> <topic>
            OPTIONAL {
                ?this :topic ?topic .
                BIND(IRI(CONCAT(STR(:), ?verbForm, "_", ?annName, "_about_", ?hashSub)) AS ?propAbout)
            }
        }
        """ ;
            sh:order 2 ] ;
    sh:targetClass :Announcement .

:Association_shape a :Situation_shape, sh:NodeShape ;
    rdfs:label "Association (shape)"@en ;
    sh:property [ sh:name "analogue"@en ; sh:nodeKind sh:BlankNodeOrIRI ; sh:path :analogue ] ;
    sh:property [ sh:name "associator"@en ; sh:nodeKind sh:BlankNodeOrIRI ; sh:path :associator ] ;
    sh:property [ sh:name "attribute"@en ; sh:nodeKind sh:BlankNodeOrIRI ; sh:path :attribute ] ;
    sh:property [ sh:name "basis"@en ; sh:nodeKind sh:BlankNodeOrIRI ; sh:path :basis ] ;
    sh:property [ sh:name "evaluator"@en ; sh:nodeKind sh:BlankNodeOrIRI ; sh:path :evaluator ] ;
    sh:property [ sh:name "requirement"@en ; sh:nodeKind sh:BlankNodeOrIRI ; sh:path :requirement ] ;
    sh:property [ sh:name "topic"@en ; sh:nodeKind sh:BlankNodeOrIRI ; sh:path :topic ]  ;
    sh:rule [ a sh:SPARQLRule ;
            sh:construct """
        PREFIX : <https://falcontologist.github.io/shacl-demo/ontology/>
        
        CONSTRUCT {
            ?associator ?opaqueProperty ?analogue .
        }
        WHERE {
            ?this a :Association ;
                  :lemma ?lemma ;
                  :synset ?synset ;
                  :associator ?associator ;
                  :analogue ?analogue .
            
            # Look up the proper 3ps inflection from the lemma node
            ?lemmaNode :lemma ?lemma ;
                       :present3sg ?verbForm .
            
            BIND(SHA256(CONCAT(?lemma, "|", ?synset)) AS ?hash)
            BIND(IRI(CONCAT(STR(:), ?verbForm, "_", SUBSTR(STR(?hash), 1, 12))) AS ?opaqueProperty)
        }
        """ ;
            sh:order 2 ] ;
    sh:targetClass :Association .

:Attack_shape a :Situation_shape, sh:NodeShape ;
    rdfs:label "Attack (shape)"@en ;
